{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/css/(.*)", "destination": "/public/css/$1" },
    { "source": "/js/(.*)", "destination": "/public/js/$1" },
    { "source": "/proposal.html", "destination": "/public/proposal.html" },
    { "source": "/index.html", "destination": "/public/index.html" },
    { "source": "/", "destination": "/public/index.html" }
  ]
}
